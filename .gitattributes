# Globale Einstellungen für Zeilenenden (verhindert CRLF vs LF Probleme)
* text=auto

# JSON Dateien explizit als Text markieren
*.json text

# Sicherstellen, dass Shell-Skripte oder Python-Skripte LF (Linux) Zeilenenden behalten
*.py text eol=lf
*.sh text eol=lf

# Verhindern, dass Git versucht, JSON Dateien bei Merges "intelligent" zu mergen, 
# wenn sie ohnehin komplett überschrieben werden
status/*.json merge=union
history/*.json merge=union
